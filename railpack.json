{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "bun": "1.3.10"
  },
  "steps": {
    "install": {
      "commands": ["bun install --frozen-lockfile"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["bun run build"]
    }
  },
  "deploy": {
    "inputs": [{ "step": "build" }],
    "startCommand": "bun run start",
    "variables": {
      "GUIDE_HOST": "0.0.0.0"
    }
  }
}
