{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "bun": "1.3.10"
  },
  "steps": {
    "install": {
      "commands": [
        {
          "dest": "package.json",
          "src": "package.json"
        },
        {
          "dest": "bun.lock",
          "src": "bun.lock"
        },
        {
          "cmd": "bun install --frozen-lockfile"
        }
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        {
          "dest": ".",
          "src": "."
        },
        {
          "cmd": "bun run build"
        }
      ]
    }
  },
  "deploy": {
    "inputs": [{ "step": "build" }],
    "startCommand": "bun run start",
    "variables": {
      "GUIDE_HOST": "0.0.0.0"
    }
  }
}
