{
  "name": "vertu-brand-guide",
  "version": "4.0.0",
  "dependencies": {
    "@elysiajs/static": "1.4.7",
    "@fontsource/dm-sans": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/instrument-serif": "5.2.8",
    "@fontsource/playfair-display": "5.2.8",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/cli": "4.2.1",
    "@types/bun": "1.3.10",
    "daisyui": "5.5.19",
    "docx": "9.6.0",
    "elysia": "1.4.27",
    "htmx.org": "2.0.8",
    "pptxgenjs": "4.0.1",
    "prismjs": "1.30.0",
    "satori": "0.25.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "description": "SSR-first VERTU brand guide with Bun, Elysia, HTMX, Tailwind CSS 4, and daisyUI 5",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "bun run build:templates && bun run build:app",
    "build:app": "bun run ./scripts/build-app.ts",
    "audit": "bun run ./scripts/audit-brand-guide.ts",
    "build:templates": "bun run ./scripts/generate-templates.mjs",
    "dev": "bun ./scripts/dev.ts",
    "lint": "biome lint . && stylelint \"src/**/*.css\" \"styles/**/*.css\"",
    "lint:fix": "biome lint --write . && stylelint --fix \"src/**/*.css\" \"styles/**/*.css\"",
    "format": "bunx prettier --write \"src/**/*.ts\" \"src/**/*.css\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"scripts/**/*.ts\" \"README.md\" \"README.zh-CN.md\" \"package.json\"",
    "format:check": "bunx prettier --check \"src/**/*.ts\" \"src/**/*.css\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"scripts/**/*.ts\" \"README.md\" \"README.zh-CN.md\" \"package.json\"",
    "preaudit": "bun run lint && bun run build",
    "preserve": "bun run build",
    "pretest": "bun run lint && bun run build",
    "pretypecheck": "bun run lint && bun run build",
    "serve": "bun ./src/server/serve.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/prismjs": "1.26.6",
    "prettier": "3.8.1",
    "stylelint": "17.4.0"
  }
}
