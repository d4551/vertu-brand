# VERTU Brand Guide — Environment template
# Copy to .env or .env.local and adjust as needed.
# Never commit .env or .env.local — they are gitignored.

# Shared listen hostname and canonical local origin host
# GUIDE_HOST=localhost

# Default development server port before GUIDE_PORT/CLI overrides
# GUIDE_DEFAULT_PORT=3000

# Default static-preview port before GUIDE_PORT overrides
# GUIDE_SERVE_PORT=3090

# Server port override (applies to both dev and serve entrypoints)
# GUIDE_PORT=3000

# Fallback port (index.ts only; GUIDE_PORT takes precedence)
# PORT=3000

# Request/response correlation header propagated by the server
# GUIDE_REQUEST_ID_HEADER=x-request-id

# Cache policy overrides (seconds)
# GUIDE_STATIC_ASSET_MAX_AGE_SECONDS=3600
# GUIDE_STATIC_ASSET_STALE_WHILE_REVALIDATE_SECONDS=86400
# GUIDE_MANIFEST_MAX_AGE_SECONDS=3600
# GUIDE_MANIFEST_STALE_WHILE_REVALIDATE_SECONDS=86400
# GUIDE_SOCIAL_ASSET_MAX_AGE_SECONDS=86400
# GUIDE_SOCIAL_ASSET_STALE_WHILE_REVALIDATE_SECONDS=604800

# Dev watcher tuning
# GUIDE_DEV_BUILD_DEBOUNCE_MS=150
# GUIDE_DEV_WATCHER_WARMUP_MS=1000

# Template generation: use system-safe fonts when 1 (avoids custom font embedding)
# VERTU_TEMPLATE_SAFE_FONTS=1
