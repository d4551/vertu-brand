{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "types": ["bun"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [".generated/**/*.ts", "src/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts"]
}
