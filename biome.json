{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "biome.json",
      "index.html",
      "package.json",
      "src/**/*.ts",
      "scripts/**/*.mjs",
      "scripts/**/*.ts",
      "tests/**/*.ts"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
